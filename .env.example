CLAUDE_API_KEY=
# Claude — modelo e comportamento (steps roteiro + imagens)
# CLAUDE_MODEL: modelo da API Anthropic (default: claude-opus-4-7)
# CLAUDE_MAX_TOKENS: limite de tokens de saida (default: 16000)
# CLAUDE_THINKING: adaptive (Opus 4.7), disabled (sem thinking, permite temperature), ou vazio (sem thinking)
CLAUDE_MODEL=claude-opus-4-7
CLAUDE_MAX_TOKENS=16000
CLAUDE_THINKING=adaptive

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Step 3 (imagens/videos): use o CLI Higgsfield + credentials.json (nao exige as chaves abaixo).
# Opcional: HIGGSFIELD_CLI_PATH, HIGGSFIELD_CREDENTIALS_PATH, HIGGSFIELD_CLI_WAIT_TIMEOUT (ex.: 15m)
HIGGSFIELD_API_KEY_ID=
HIGGSFIELD_API_KEY_SECRET=
