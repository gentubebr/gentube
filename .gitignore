.env
node_modules/
dist/
*.log
.DS_Store
._.DS_Store
data/

# Runbook local — não versionar (cada máquina mantém o seu)
/EXAMPLE.md

# Scripts e automação locais
/scripts/

# Avatares (imagens locais; não enviar ao remoto)
/Avatars/

# Projetos de vídeo gerados — no clone a pasta Videos/ fica vazia (só .gitkeep)
/Videos/*
!/Videos/.gitkeep

# Transcrições de referência locais (não versionar conteúdo; só .gitkeep no clone)
/Transcripts/*
!/Transcripts/.gitkeep
